def generate_website(info: dict) -> str:
    """Chiama Claude API e genera il sito web completo"""

    api_key = os.environ.get("ANTHROPIC_API_KEY")
    if not api_key:
        print(f"\n{C.RED}  ✗ ANTHROPIC_API_KEY non trovata nelle variabili d'ambiente.{C.RESET}")
        print(f"  {C.DIM}Esporta la chiave: export ANTHROPIC_API_KEY='la-tua-chiave'{C.RESET}")
        sys.exit(1)

    client = anthropic.Anthropic(api_key=api_key)
    prompt = build_prompt(info)

    spinner_msg("Claude AI sta generando il tuo sito web (questo richiede 30-60 secondi)")

    chunks = []
    char_count = 0

    with client.messages.stream(
        model="claude-opus-4-5",
        max_tokens=16000,
        system=SYSTEM_PROMPT,
        messages=[{"role": "user", "content": prompt}],
    ) as stream:
        for text in stream.text_stream:
            chunks.append(text)
            char_count += len(text)
            # Progress indicator
            if char_count % 500 == 0:
                bars = "█" * min(40, char_count // 300)
                print(f"\r  {C.CYAN}{bars}{C.RESET} {char_count:,} caratteri...", end="", flush=True)

    print()  # newline dopo progress
    return "".join(chunks)

# ─── SALVATAGGIO E OUTPUT ────────────────────────────────────────

def save_website(html: str, nome: str) -> Path:
    """Salva il sito web generato"""

    # Crea directory output
    output_dir = Path("siti_generati")
    output_dir.mkdir(exist_ok=True)

    # Nome file sicuro
    safe_name = re.sub(r'[^a-zA-Z0-9_-]', '_', nome.lower().replace(" ", "_"))
    timestamp = datetime.now().strftime("%Y%m%d_%H%M%S")
    filename = output_dir / f"{safe_name}_{timestamp}.html"

    # Scrivi file
    filename.write_text(html, encoding="utf-8")
    return filename

def save_config(info: dict, output_path: Path):
    """Salva la configurazione JSON accanto al sito"""
    config_path = output_path.with_suffix(".json")
    # Rimuovi oggetti non serializzabili se presenti
    config_data = {k: v for k, v in info.items()}
    config_path.write_text(
        json.dumps(config_data, ensure_ascii=False, indent=2),
        encoding="utf-8"
    )

