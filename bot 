def ask(prompt: str, default: str = "") -> str:
    """Prompt interattivo con stile"""
    suffix = f" {C.DIM}[{default}]{C.RESET}" if default else ""
    value = input(f"{C.CYAN}▸{C.RESET} {C.WHITE}{prompt}{C.RESET}{suffix}: ").strip()
    return value if value else default

def ask_multi(prompt: str, hint: str = "separati da virgola") -> list[str]:
    """Chiede una lista di valori"""
    print(f"{C.CYAN}▸{C.RESET} {C.WHITE}{prompt}{C.RESET} {C.DIM}({hint}){C.RESET}:")
    value = input("  → ").strip()
    return [v.strip() for v in value.split(",") if v.strip()]

